// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// =======================
// ENUMS
// =======================
enum Role {
  super_admin
  hall_admin
  hall_employee
}

enum HallStatus {
  active
  inactive
  suspended
}

enum MessageStatus {
  pending
  sent
  delivered
  read
  failed
}

// =======================
// MODELS
// =======================

model User {
  id             Int         @id @default(autoincrement())
  name           String
  email          String      @unique
  passwordHash   String      @map("password_hash")
  role           Role
  lastLoginAt    DateTime?   @map("last_login_at")
  hallId         Int?        @map("hall_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  // Relations
  ownedHalls     Hall[]      @relation("HallOwner")
  createdInvites Invitation[] @relation("InvitationCreator")
  hall           Hall?       @relation("HallEmployees", fields: [hallId], references: [id])

  @@map("users")
}

model Hall {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  address     String
  email       String
  phone       String
  status      HallStatus @default(inactive)
  ownerId     Int        @map("owner_id")
  balance     Int        @default(0)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // Relations
  owner       User       @relation("HallOwner", fields: [ownerId], references: [id])
  employees   User[]     @relation("HallEmployees")
  invitations Invitation[]

  @@map("halls")
}

model Invitation {
  id          Int         @id @default(autoincrement())
  title       String
  description String?
  eventDate   DateTime    @map("event_date")
  hallId      Int         @map("hall_id")
  creatorId   Int         @map("creator_id")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Relations
  hall        Hall        @relation(fields: [hallId], references: [id])
  creator     User        @relation("InvitationCreator", fields: [creatorId], references: [id])
  messages    InvitationMessage[]
  recipients  InvitationRecipient[]

  @@map("invitations")
}

model InvitationMessage {
  id           Int                   @id @default(autoincrement())
  content      String
  invitationId Int                   @map("invitation_id")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  // Relations
  invitation   Invitation            @relation(fields: [invitationId], references: [id])
  recipients   InvitationRecipient[]

  @@map("invitation_message")
}

model InvitationRecipient {
  id                  Int             @id @default(autoincrement())
  invitationId        Int             @map("invitation_id")
  invitationMessageId Int             @map("invitation_message_id")
  recipientName       String          @map("recipient_name")
  phoneNumber         String          @map("phone_number")
  messageStatus       MessageStatus   @default(pending) @map("message_status")
  sendAt              DateTime        @map("send_at")
  sentAt              DateTime?       @map("sent_at")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  // Relations
  invitation        Invitation        @relation(fields: [invitationId], references: [id])
  invitationMessage InvitationMessage @relation(fields: [invitationMessageId], references: [id])

  @@map("invitation_recipient")
}
